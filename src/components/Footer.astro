---
// Footer.astro
// Propósito: Pie anclado al fondo del viewport. shrink-0 dentro del flex-col del Layout
// garantiza que no se comprima y quede siempre visible sin scroll.
---

<footer class="shrink-0 w-full border-t border-white/30 bg-white/10 backdrop-blur-md">
	<div class="mx-auto flex w-full max-w-6xl flex-col items-center gap-2 px-4 py-3
	            sm:flex-row sm:justify-between sm:gap-4 sm:px-6 sm:py-4">
		<!-- Marca -->
		<a href="/" class="font-[family-name:var(--font-title)] text-base sm:text-lg font-bold">
			nube<span class="text-brand-pink">colores</span>
		</a>

		<!-- Copyright -->
		<p class="text-[0.7rem] sm:text-xs text-ink/60">
			&copy; 2024 Nube de Colores. Hecho con ternura.
		</p>

		<!-- Redes sociales -->
		<div class="flex gap-2">
			<a href="#" aria-label="Instagram"
			   class="flex h-8 w-8 items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
					<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
					<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
				</svg>
			</a>
			<a href="#" aria-label="Pinterest"
			   class="flex h-8 w-8 items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="12" x2="12" y1="8" y2="16"/>
					<line x1="8" x2="16" y1="12" y2="12"/>
					<circle cx="12" cy="12" r="10"/>
				</svg>
			</a>
		</div>
	</div>
</footer>
