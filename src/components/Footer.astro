---
// Footer.astro
// Propósito: Pie anclado al fondo del viewport (shrink-0 dentro del flex-col del Layout).
// Mobile: logo oculto y redes sociales colapsadas en <details> que abre hacia arriba
// (bottom-full) para minimizar la altura del footer y respetar el no-scroll.
---

<footer class="relative z-40 shrink-0 w-full border-t border-white/30 bg-white/10 backdrop-blur-md">
	<div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-3 px-4 py-2
	            sm:gap-4 sm:px-6 sm:py-4">

		<!-- Redes desktop: visibles en línea -->
		<div class="hidden sm:flex gap-2">
			<a href="#" aria-label="Instagram"
			   class="flex h-8 w-8 items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
					<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
					<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
				</svg>
			</a>
			<a href="#" aria-label="Facebook"
			   class="flex h-8 w-8 items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
					<path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
				</svg>
			</a>
			<a href="#" aria-label="TikTok"
			   class="flex h-8 w-8 items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
					<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.55a8.16 8.16 0 0 0 4.77 1.52V6.69h-1.84z"/>
				</svg>
			</a>
		</div>

		<!-- Copyright -->
		<p class="text-[0.7rem] sm:text-xs text-ink/60 text-center">
			&copy; 2026 Nube de Colores. Hecho con ternura.
		</p>

		<!-- Marca (oculta en mobile para minimizar altura) -->
		<a href="/" class="hidden sm:block font-[family-name:var(--font-title)] text-sm sm:text-lg font-bold shrink-0">
 			nube<span class="text-brand-blue">colores</span>
		</a>

		<!-- Redes mobile: dropdown hacia arriba con <details> nativo -->
		<details class="sm:hidden relative group">
			<summary
				class="flex h-8 w-8 cursor-pointer list-none items-center justify-center rounded-full bg-white/30 transition-colors hover:bg-brand-blue hover:text-paper [&::-webkit-details-marker]:hidden"
				aria-label="Mostrar redes sociales">
				<!-- Icono share cerrado → X al abrir -->
				<svg class="group-open:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="18" cy="5" r="3"/>
					<circle cx="6" cy="12" r="3"/>
					<circle cx="18" cy="19" r="3"/>
					<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
					<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
				</svg>
				<svg class="hidden group-open:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="6" y1="6" x2="18" y2="18"/>
					<line x1="18" y1="6" x2="6" y2="18"/>
				</svg>
			</summary>

			<!-- Panel ascendente animado (translate desde abajo + fade).
			     z-50 garantiza que flote sobre blobs/burbujas del Hero. -->
			<div class="absolute bottom-[calc(100%+0.5rem)] right-0 z-50
			            flex flex-col gap-2 rounded-2xl border border-white/50 bg-white/70 p-2
			            shadow-[var(--shadow-float)] backdrop-blur-xl
			            origin-bottom-right
			            opacity-0 translate-y-2 scale-95 pointer-events-none
			            transition duration-200 ease-out
			            group-open:opacity-100 group-open:translate-y-0 group-open:scale-100 group-open:pointer-events-auto">
				<a href="#" aria-label="Instagram"
				   class="flex h-9 w-9 items-center justify-center rounded-full bg-white/60 transition-colors hover:bg-brand-blue hover:text-paper">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
						<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
					</svg>
				</a>
				<a href="#" aria-label="Facebook"
				   class="flex h-9 w-9 items-center justify-center rounded-full bg-white/60 transition-colors hover:bg-brand-blue hover:text-paper">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
					</svg>
				</a>
				<a href="#" aria-label="TikTok"
				   class="flex h-9 w-9 items-center justify-center rounded-full bg-white/60 transition-colors hover:bg-brand-blue hover:text-paper">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.55a8.16 8.16 0 0 0 4.77 1.52V6.69h-1.84z"/>
				</svg>
				</a>
			</div>
		</details>
	</div>
</footer>
