---
// Hero.astro
// Propósito: Sección principal. Ocupa el main flexible (flex-1) sin desbordar.
// Tipografía fluida (clamp) y grid responsivo para caber en la vista sin scroll.
---

<section class="relative flex-1 min-h-0 flex items-center overflow-hidden px-4 sm:px-6 lg:px-8">
	<div class="relative mx-auto grid w-full max-w-6xl items-center gap-6 md:gap-10
	            grid-cols-1 md:grid-cols-2">
		<!-- Contenido -->
		<div class="relative z-10 flex flex-col items-center text-center md:items-start md:text-left">
			<span class="mb-3 inline-block rounded-[var(--radius-pill)] bg-white/40
			             px-3 py-1 text-[0.7rem] sm:text-xs font-bold uppercase tracking-wider text-brand-pink">
				Nuevas Aventuras 2026
			</span>

			<h1 class="mb-3 leading-tight"
			    style="font-size: clamp(1.75rem, 4.5vw + 0.5rem, 3.5rem);">
				Viste su <span class="text-white drop-shadow-sm">imaginación</span> con suavidad
			</h1>

			<p class="mb-5 max-w-md text-black/70"
			   style="font-size: clamp(0.85rem, 0.6vw + 0.75rem, 1.05rem);">
				Ropa diseñada para jugar, crecer y soñar. Algodón orgánico y colores que acompañan cada paso.
			</p>

			<div class="flex flex-wrap justify-center gap-3 md:justify-start">
				<a href="#"
				   class="rounded-[var(--radius-pill)] bg-brand-pink px-5 py-2.5 text-sm sm:text-base font-bold text-paper
				          transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-float)]">
					Ver Colección
				</a>
				<a href="#"
				   class="rounded-[var(--radius-pill)] border border-black/5 bg-paper px-5 py-2.5 text-sm sm:text-base font-bold text-brand-blue
				          transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-float)]">
					Niños & Niñas
				</a>
			</div>
		</div>

		<!-- Visual: blob + burbujas -->
		<!-- Mobile: absoluto, centrado, z-0 y opacidad baja para no tapar texto -->
		<!-- Desktop: columna de grid normal con opacidad completa -->
		<div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center opacity-20
		            md:pointer-events-auto md:relative md:inset-auto md:opacity-100 md:z-auto">
			<div class="relative aspect-square w-[96vw] max-w-sm
			            overflow-hidden bg-white/20 shadow-[var(--shadow-subtle)]
			            md:w-full md:max-w-[min(39rem,63vh)]"
			     style="border-radius: var(--radius-blob); animation: var(--animate-morph);">
				<img
					src="/imgHero.png"
					alt="Niños jugando"
					class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
				/>
			</div>

			<!-- Burbujas decorativas -->
			<span class="pointer-events-none absolute -top-3 right-4 h-14 w-14 rounded-full bg-brand-blue/40 backdrop-blur-sm"
			      style="animation: var(--animate-float-slow);"></span>
			<span class="pointer-events-none absolute -bottom-4 -left-3 h-20 w-20 rounded-full bg-brand-pink/40 backdrop-blur-sm"
			      style="animation: var(--animate-float-slow); animation-delay: -3s;"></span>
		</div>
	</div>
</section>
