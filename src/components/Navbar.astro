---
// Navbar.astro
// Propósito: Barra flotante tipo píldora con glassmorphism.
// Mobile: enlaces y acciones colapsan en un <details> con animación suave.
// La lupa NO cierra el menú; abre un <input> de búsqueda inline (data-search-toggle).
---

<nav class="shrink-0 w-full px-3 pt-3 sm:px-6 sm:pt-6 z-50">
	<div class="relative mx-auto flex w-full max-w-6xl items-center justify-between gap-3
	            rounded-[var(--radius-pill)] border border-white/50 bg-white/40
	            px-4 py-2 sm:px-8 sm:py-3
	            shadow-[var(--shadow-subtle)] backdrop-blur-md">
		<!-- Logo -->
		<a href="/" class="font-[family-name:var(--font-title)] text-xl sm:text-2xl font-bold">
			nube<span class="text-brand-blue/80">colores</span>
		</a>

		<!-- Enlaces desktop -->
		<ul class="hidden md:flex gap-8 text-sm font-medium lowercase tracking-wider">
			<li><a href="#">niñas</a></li>
			<li><a href="#">niños</a></li>
			<li><a href="#">bebés</a></li>
			<li><a href="#">colección</a></li>
		</ul>

		<!-- Acciones desktop -->
		<div class="hidden md:flex items-center gap-2">
			<button class="flex h-9 w-9 items-center justify-center rounded-full transition-colors hover:bg-white/40" aria-label="Buscar">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
				</svg>
			</button>
			<button class="flex h-9 w-9 items-center justify-center rounded-full transition-colors hover:bg-white/40" aria-label="Carrito">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
					<path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
				</svg>
			</button>
		</div>

		<!-- Hamburguesa mobile: <details> con animación descendente -->
		<details class="md:hidden group">
			<summary
				class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full transition-colors hover:bg-white/40 [&::-webkit-details-marker]:hidden"
				aria-label="Abrir menú">
				<svg class="group-open:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="4" y1="7" x2="20" y2="7"/>
					<line x1="4" y1="12" x2="20" y2="12"/>
					<line x1="4" y1="17" x2="20" y2="17"/>
				</svg>
				<svg class="hidden group-open:block" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="6" y1="6" x2="18" y2="18"/>
					<line x1="18" y1="6" x2="6" y2="18"/>
				</svg>
			</summary>

			<!-- Panel animado: opacity + translate con transición 200ms.
			     Cerrado usa pointer-events-none para no interceptar clicks. -->
			<div class="absolute right-2 top-[calc(100%+0.5rem)] w-60
			            rounded-3xl border border-white/50 bg-white/70 p-4
			            shadow-[var(--shadow-float)] backdrop-blur-xl
			            origin-top-right
			            opacity-0 -translate-y-2 scale-95 pointer-events-none
			            transition duration-200 ease-out
			            group-open:opacity-100 group-open:translate-y-0 group-open:scale-100 group-open:pointer-events-auto">
				<ul class="flex flex-col gap-3 text-sm font-medium lowercase tracking-wider">
					<li><a href="#" class="block py-1">niñas</a></li>
					<li><a href="#" class="block py-1">niños</a></li>
					<li><a href="#" class="block py-1">bebés</a></li>
					<li><a href="#" class="block py-1">colección</a></li>
				</ul>
				<div class="mt-3 flex items-center gap-2 border-t border-black/10 pt-3">
					<!-- Lupa: data-no-close evita cierre del details.
					     data-search-toggle dispara el mostrar/ocultar del input. -->
					<button
						type="button"
						data-no-close
						data-search-toggle
						class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white/60 transition-colors hover:bg-white"
						aria-label="Buscar">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
						</svg>
					</button>
					<!-- Input de búsqueda: oculto por defecto, animado al aparecer -->
					<input
						data-search-input
						data-no-close
						type="search"
						placeholder="Buscar..."
						class="hidden w-0 opacity-0 rounded-full border border-black/10 bg-white/80 px-3 py-1.5
						       text-sm outline-none transition-all duration-200
						       data-[open=true]:block data-[open=true]:w-full data-[open=true]:opacity-100
						       focus:border-brand-pink"
					/>
					<button class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white/60 transition-colors hover:bg-white" aria-label="Carrito">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
							<path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
						</svg>
					</button>
				</div>
			</div>
		</details>
	</div>
</nav>

<script>
	// Toggle del input de búsqueda. No cierra el <details>.
	// Alterna display + ancho + opacidad para animar aparición suave.
	document.querySelectorAll<HTMLButtonElement>('[data-search-toggle]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const wrapper = btn.closest('details');
			const input = wrapper?.querySelector<HTMLInputElement>('[data-search-input]');
			if (!input) return;
			const isHidden = input.classList.contains('hidden');
			if (isHidden) {
				input.classList.remove('hidden');
				// Rerender antes de aplicar transición
				requestAnimationFrame(() => {
					input.classList.remove('w-0', 'opacity-0');
					input.classList.add('w-full', 'opacity-100');
					input.focus();
				});
			} else {
				input.classList.add('w-0', 'opacity-0');
				input.classList.remove('w-full', 'opacity-100');
				setTimeout(() => input.classList.add('hidden'), 200);
			}
		});
	});
</script>
