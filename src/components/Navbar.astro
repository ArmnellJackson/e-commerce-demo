---
// Navbar.astro
// Propósito: Barra flotante tipo píldora con fondo glassmorphism.
// En la columna flex del Layout, shrink-0 evita que colapse en pantallas bajas.
---

<nav class="shrink-0 w-full px-3 pt-3 sm:px-6 sm:pt-6 z-50">
	<div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-3
	            rounded-[var(--radius-pill)] border border-white/50 bg-white/40
	            px-4 py-2 sm:px-8 sm:py-3
	            shadow-[var(--shadow-subtle)] backdrop-blur-md">
		<!-- Logo -->
		<a href="/" class="font-[family-name:var(--font-title)] text-xl sm:text-2xl font-bold">
			nube<span class="text-brand-blue/80">colores</span>
		</a>

		<!-- Enlaces (ocultos en mobile) -->
		<ul class="hidden md:flex gap-8 text-sm font-medium lowercase tracking-wider">
			<li><a href="#">niñas</a></li>
			<li><a href="#">niños</a></li>
			<li><a href="#">bebés</a></li>
			<li><a href="#">colección</a></li>
		</ul>

		<!-- Acciones -->
		<div class="flex items-center gap-1 sm:gap-2">
			<button
				class="flex h-9 w-9 items-center justify-center rounded-full text-ink transition-colors hover:bg-white/40"
				aria-label="Buscar">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
				</svg>
			</button>
			<button
				class="flex h-9 w-9 items-center justify-center rounded-full text-ink transition-colors hover:bg-white/40"
				aria-label="Carrito">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
					<path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
				</svg>
			</button>
		</div>
	</div>
</nav>
