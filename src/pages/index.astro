---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

// Propósito: Página de inicio que integra los componentes principales.
---

<Layout>
	<Navbar />
	<main>
		<Hero />
		<!-- Aquí se pueden añadir secciones de productos, categorías, etc. -->
	</main>
	<Footer />
</Layout>

<style>
	main {
		width: 100%;
		display: flex;
		flex-direction: column;
	}
</style>
