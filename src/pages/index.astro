---
// index.astro
// Propósito: Página de inicio. La isla <Shell client:load> (React) gestiona Navbar
// + main reactivos: Hero por defecto (slot Astro) o catálogo de cards al elegir categoría.
import Layout from '../layouts/Layout.astro';
import { Shell } from '../components/Shell';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Shell client:load>
		<Hero />
	</Shell>
	<Footer />
</Layout>
