---
// Layout.astro
// Propósito: Shell global. Bloquea scroll de viewport (h-dvh + overflow-hidden)
// y expone columna flex para fijar footer al fondo con main flexible en medio.
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="h-dvh overflow-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Nube de Colores | E-commerce Infantil</title>
		<!-- Fuentes: Comfortaa (títulos) y Lato (cuerpo) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
			href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=Lato:wght@300;400;700;900&display=swap"
			rel="stylesheet"
		>
	</head>
	<body class="h-dvh overflow-hidden flex flex-col">
		<slot />
	</body>
</html>
