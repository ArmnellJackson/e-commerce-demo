---
// Layout.astro
// Propósito: Shell global. Bloquea scroll de viewport (h-dvh + overflow-hidden)
// y expone columna flex para fijar footer al fondo con main flexible en medio.
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="h-dvh overflow-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Nube de Colores | E-commerce Infantil</title>
		<!-- Fuentes: Comfortaa (títulos) y Lato (cuerpo) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
			href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=Lato:wght@300;400;700;900&display=swap"
			rel="stylesheet"
		>
	</head>
	<body class="h-dvh overflow-hidden flex flex-col">
		<slot />

		<!--
			Script global para <details>:
			- Cierra el panel abierto al hacer click fuera (outside-click).
			- Cierra el panel al hacer click en cualquier enlace o botón interno
			  (excepto el <summary>, que conserva su toggle nativo).
		-->
		<script>
			// Cierre por click fuera: si el click no está dentro del <details>, se cierra.
			document.addEventListener('click', (e) => {
				const target = e.target as Node;
				document.querySelectorAll<HTMLDetailsElement>('details[open]').forEach((d) => {
					if (!d.contains(target)) d.open = false;
				});
			});

			// Cierre al pulsar un elemento interno (enlace/botón) del panel.
			// Excepciones: summary (toggle nativo) y cualquier nodo con data-no-close
			// (ej. lupa que abre input inline sin cerrar el menú).
			document.querySelectorAll<HTMLDetailsElement>('details').forEach((d) => {
				d.addEventListener('click', (e) => {
					const el = e.target as HTMLElement;
					if (el.closest('summary')) return;
					if (el.closest('[data-no-close]')) return;
					if (el.closest('a, button')) d.open = false;
				});
			});
		</script>
	</body>
</html>
